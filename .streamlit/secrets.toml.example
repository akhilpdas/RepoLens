# Copy this file to `secrets.toml` (locally) or paste into the Streamlit Cloud
# "Secrets" UI when deploying. Do NOT commit `secrets.toml` to git.

GROQ_API_KEY = "gsk_your_groq_api_key_here"

# Optional: lifts GitHub API rate limit from 60 -> 5000 req/hr and unlocks
# private repos. Generate at https://github.com/settings/tokens
GITHUB_TOKEN = "ghp_your_github_personal_access_token_here"
