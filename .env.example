# RepoLens Environment Configuration

# Groq API Key (required)
# Get your free API key at: https://console.groq.com/keys
# Sign up, generate a key, copy it immediately (Groq only shows it once), and paste it below.
GROQ_API_KEY=gsk_your_actual_api_key_here

# GitHub Personal Access Token (optional but recommended)
# Without a token: 60 GitHub API requests/hour (rate limit hit easily on medium repos)
# With a token:    5,000 requests/hour AND access to private repos
# Create at: https://github.com/settings/tokens (classic, scope: repo for private; public_repo otherwise)
# GITHUB_TOKEN=ghp_your_token_here

# Optional: Google Gemini API Key (for future use)
# GEMINI_API_KEY=your_gemini_key_here

# Optional: OpenAI API Key (for future use)
# OPENAI_API_KEY=sk_your_openai_key_here

# Optional: ChromaDB persistent cache path (default: ./.chroma_cache)
# CHROMA_PATH=./.chroma_cache
